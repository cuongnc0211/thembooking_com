<div class="w-full max-w-sm mx-auto">
  <div class="text-center mb-8">
    <span class="text-2xl font-bold text-white">ThemBooking</span>
    <span class="ml-2 text-xs font-medium bg-indigo-500/20 text-indigo-300 px-2 py-0.5 rounded-full">Admin</span>
  </div>

  <div class="bg-gray-800 rounded-2xl border border-gray-700 p-8">
    <h1 class="text-xl font-bold text-white text-center mb-6">Staff Sign In</h1>

    <% if flash[:alert] %>
      <div class="mb-4 p-3 rounded-lg bg-red-500/10 text-red-400 text-sm border border-red-500/20">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: admin_sign_in_path, method: :post, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= form.email_field :email_address, required: true, autofocus: true,
            autocomplete: "username",
            placeholder: "staff@thembooking.com",
            class: "w-full px-4 py-3 rounded-xl bg-gray-700 border border-gray-600 text-white
                    placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= form.password_field :password, required: true,
            autocomplete: "current-password",
            placeholder: "Enter password",
            maxlength: 72,
            class: "w-full px-4 py-3 rounded-xl bg-gray-700 border border-gray-600 text-white
                    placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      </div>

      <%= form.submit "Sign In",
          class: "w-full py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-medium
                  rounded-xl transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
