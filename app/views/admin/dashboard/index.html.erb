<% admin_breadcrumbs("Dashboard") %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Admin Dashboard</h1>
  <p class="text-sm text-gray-500 mt-1">Welcome back, <%= current_staff.name %></p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <p class="text-sm font-medium text-gray-500">Total Users</p>
    <p class="text-3xl font-bold text-gray-900 mt-1"><%= User.count %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <p class="text-sm font-medium text-gray-500">Total Businesses</p>
    <p class="text-3xl font-bold text-gray-900 mt-1"><%= Business.count %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <p class="text-sm font-medium text-gray-500">Total Bookings</p>
    <p class="text-3xl font-bold text-gray-900 mt-1"><%= Booking.count %></p>
  </div>
</div>
