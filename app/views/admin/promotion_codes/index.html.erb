<% admin_breadcrumbs("Promotion Codes") %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Promotion Codes</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @total %> total codes</p>
  </div>
  <%= link_to "New Promotion Code", new_admin_promotion_code_path,
      class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg" %>
</div>

<%# Search form %>
<div class="mb-4">
  <%= form_with url: admin_promotion_codes_path, method: :get, local: true, class: "flex gap-2" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Search by code or description…",
        class: "block w-full max-w-sm rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    <%= f.submit "Search", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg cursor-pointer" %>
    <% if params[:q].present? %>
      <%= link_to "Clear", admin_promotion_codes_path, class: "px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg" %>
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Code</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Value</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Usage</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Valid Period</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @promotion_codes.each do |pc| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= link_to pc.code, admin_promotion_code_path(pc), class: "hover:text-indigo-600 font-mono" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= pc.discount_type.humanize %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium">
              <% if pc.percentage? %>
                <%= "#{number_with_precision(pc.discount_value, precision: 2, strip_insignificant_zeros: true)}%" %>
              <% else %>
                <%= number_to_currency(pc.discount_value) %>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= pc.used_count %> / <%= pc.usage_limit || "unlimited" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <% if pc.valid_from.present? || pc.valid_until.present? %>
                <span class="block"><%= pc.valid_from&.strftime("%b %d, %Y") || "—" %></span>
                <span class="block text-xs text-gray-400">to <%= pc.valid_until&.strftime("%b %d, %Y") || "no end" %></span>
              <% else %>
                <span class="text-gray-400">Always valid</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <% if pc.expired? %>
                <span class="bg-yellow-100 text-yellow-800 rounded-full px-2 py-0.5 text-xs font-medium">Expired</span>
              <% elsif pc.active? %>
                <span class="bg-green-100 text-green-800 rounded-full px-2 py-0.5 text-xs font-medium">Active</span>
              <% else %>
                <span class="bg-red-100 text-red-800 rounded-full px-2 py-0.5 text-xs font-medium">Inactive</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
              <%= link_to "Show", admin_promotion_code_path(pc), class: "text-indigo-600 hover:text-indigo-800" %>
              <%= link_to "Edit", edit_admin_promotion_code_path(pc), class: "text-gray-600 hover:text-gray-800" %>
              <%= link_to pc.active? ? "Deactivate" : "Activate",
                  toggle_admin_promotion_code_path(pc),
                  data: { turbo_method: :patch, turbo_confirm: "#{pc.active? ? 'Deactivate' : 'Activate'} this promotion code?" },
                  class: pc.active? ? "text-red-600 hover:text-red-800" : "text-green-600 hover:text-green-800" %>
            </td>
          </tr>
        <% end %>
        <% if @promotion_codes.empty? %>
          <tr>
            <td colspan="7" class="px-6 py-10 text-center text-sm text-gray-400">No promotion codes found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <% total_pages = (@total.to_f / @per_page).ceil %>
  <% if total_pages > 1 %>
    <div class="px-6 py-4 border-t border-gray-200 flex items-center justify-between text-sm text-gray-500">
      <span>Page <%= @page %> of <%= total_pages %> (<%= @total %> codes)</span>
      <div class="flex gap-2">
        <% if @page > 1 %>
          <%= link_to "Previous", admin_promotion_codes_path(q: params[:q], page: @page - 1),
              class: "px-3 py-1 rounded border border-gray-300 hover:bg-gray-50" %>
        <% end %>
        <% if @page < total_pages %>
          <%= link_to "Next", admin_promotion_codes_path(q: params[:q], page: @page + 1),
              class: "px-3 py-1 rounded border border-gray-300 hover:bg-gray-50" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
