<% admin_breadcrumbs(link_to("Businesses", admin_businesses_path), link_to(@business.name, admin_business_path(@business)), "Edit") %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Edit Business</h1>
  <p class="text-sm text-gray-500 mt-1"><%= @business.slug %></p>
</div>

<div class="bg-white rounded-xl border border-gray-200 p-6 max-w-2xl">
  <%# Validation errors %>
  <% if @business.errors.any? %>
    <div class="mb-6 rounded-lg bg-red-50 border border-red-200 p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(@business.errors.count, "error") %> prevented this business from being saved:
      </h3>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% @business.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @business, url: admin_business_path(@business), method: :patch, local: true, class: "space-y-5" do |f| %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :business_type, "Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :business_type,
          Business::BUSINESS_TYPES.map { |t| [t.humanize, t] },
          {},
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :description, rows: 3, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :address, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :address, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :phone, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.telephone_field :phone, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :capacity, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :capacity, min: 1, max: 50, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :currency, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :currency, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
      <p class="mt-1 text-xs text-gray-400">e.g. USD, EUR, GBP</p>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Save Changes", class: "px-5 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg cursor-pointer" %>
      <%= link_to "Cancel", admin_business_path(@business), class: "px-5 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg" %>
    </div>

  <% end %>
</div>
