<% content_for :title, "Edit Landing Page" %>

<div class="max-w-2xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Landing Page Settings</h1>
      <p class="text-sm text-slate-500 mt-1">Customize your public business page</p>
    </div>
    <% if @business.slug.present? %>
      <%= link_to landing_page_path(@business.slug),
          target: "_blank",
          class: "flex items-center gap-1.5 text-sm text-indigo-600 hover:text-indigo-800 font-medium" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
        Preview
      <% end %>
    <% end %>
  </div>

  <%= form_with model: @business, url: dashboard_business_landing_page_path,
      method: :patch, local: true, class: "space-y-6" do |form| %>

    <%# Page URL / Slug %>
    <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
      <h2 class="text-sm font-semibold text-slate-700 mb-4">Page URL</h2>
      <div class="flex rounded-lg shadow-sm">
        <span class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-slate-300 bg-slate-50 text-slate-500 text-sm">
          thembooking.com/
        </span>
        <%= form.text_field :slug,
            class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-lg border border-slate-300 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
            placeholder: "your-business-name" %>
      </div>
      <% if @business.errors[:slug].any? %>
        <p class="mt-1 text-sm text-red-600"><%= @business.errors[:slug].first %></p>
      <% end %>
      <p class="mt-1 text-xs text-slate-400">Only lowercase letters, numbers, and hyphens. Min 3 characters.</p>
    </div>

    <%# Hero Content %>
    <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm space-y-4">
      <h2 class="text-sm font-semibold text-slate-700">Hero Content</h2>

      <div>
        <%= form.label :headline, "Headline", class: "block text-sm font-medium text-slate-600 mb-1" %>
        <%= form.text_field :headline,
            placeholder: "Welcome to #{@business.name}",
            class: "block w-full rounded-lg border-slate-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
            maxlength: 200 %>
        <% if @business.errors[:headline].any? %>
          <p class="mt-1 text-sm text-red-600"><%= @business.errors[:headline].first %></p>
        <% end %>
      </div>

      <div>
        <%= form.label :description, "Description", class: "block text-sm font-medium text-slate-600 mb-1" %>
        <%= form.text_area :description, rows: 3,
            class: "block w-full rounded-lg border-slate-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
      </div>
    </div>

    <%# Branding %>
    <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm space-y-4">
      <h2 class="text-sm font-semibold text-slate-700">Branding</h2>

      <%# Theme Color %>
      <div>
        <%= form.label :theme_color, "Brand Color", class: "block text-sm font-medium text-slate-600 mb-1" %>
        <div class="flex items-center gap-3">
          <%= form.color_field :theme_color,
              class: "h-10 w-14 rounded-lg border border-slate-300 cursor-pointer p-0.5" %>
          <%= form.text_field :theme_color,
              class: "block w-28 rounded-lg border-slate-300 shadow-sm sm:text-sm",
              pattern: "#[0-9a-fA-F]{6}",
              placeholder: "#4f46e5" %>
        </div>
        <% if @business.errors[:theme_color].any? %>
          <p class="mt-1 text-sm text-red-600"><%= @business.errors[:theme_color].first %></p>
        <% end %>
      </div>

      <%# Cover Photo %>
      <div>
        <%= form.label :cover_photo, "Cover Photo", class: "block text-sm font-medium text-slate-600 mb-1" %>
        <% if @business.cover_photo.attached? %>
          <div class="mb-2">
            <%= image_tag @business.cover_photo.variant(resize_to_limit: [600, 200]),
                class: "rounded-lg object-cover w-full max-h-40" %>
          </div>
        <% end %>
        <%= form.file_field :cover_photo,
            accept: "image/jpeg,image/png,image/webp",
            class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
        <p class="mt-1 text-xs text-slate-400">JPEG, PNG, or WebP. Max 10MB. Recommended: 1200×400px.</p>
      </div>
    </div>

    <%# Section Visibility %>
    <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
      <h2 class="text-sm font-semibold text-slate-700 mb-4">Visible Sections</h2>
      <div class="space-y-3">
        <% { show_services: "Services", show_gallery: "Gallery", show_hours: "Operating Hours", show_contact: "Contact & Map" }.each do |key, label| %>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="hidden" name="landing_page_config[<%= key %>]" value="0" />
            <input type="checkbox" name="landing_page_config[<%= key %>]" value="1"
              <%= "checked" if @business.landing_page_config&.dig(key.to_s) != false %>
              class="h-4 w-4 text-indigo-600 rounded border-slate-300 focus:ring-indigo-500" />
            <span class="text-sm text-slate-700"><%= label %></span>
          </label>
        <% end %>
      </div>
    </div>

    <%# CTA Button %>
    <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
      <h2 class="text-sm font-semibold text-slate-700 mb-4">Call-to-Action Button</h2>
      <div>
        <label class="block text-sm font-medium text-slate-600 mb-1">Button Text</label>
        <input type="text" name="landing_page_config[custom_cta_text]"
          value="<%= @business.landing_page_config&.dig('custom_cta_text').presence || 'Book Now' %>"
          class="block w-full rounded-lg border-slate-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
          maxlength="30"
          placeholder="Book Now" />
        <p class="mt-1 text-xs text-slate-400">Max 30 characters.</p>
      </div>
    </div>

    <%# Submit %>
    <div class="flex justify-end pb-8">
      <%= form.submit "Save Changes",
          class: "px-6 py-2.5 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium text-sm cursor-pointer transition-colors" %>
    </div>

  <% end %>
</div>
