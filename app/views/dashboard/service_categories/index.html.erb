<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold"><%= t('views.dashboard.service_categories.index.title') %></h1>
      <%= link_to "← Back to Branch", dashboard_branch_path(@branch), class: "text-sm text-slate-500 hover:text-slate-700" %>
    </div>
    <%= link_to t('views.dashboard.service_categories.index.add_category'),
        new_dashboard_branch_service_category_path(@branch),
        class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded" %>
  </div>

  <% if @categories.any? %>
    <div class="card overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Services</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider"><%= t('common.actions_title') %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-200">
          <% @categories.each do |category| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900"><%= category.name %></td>
              <td class="px-6 py-4 text-sm text-slate-500">
                <%= category.services.count %>
                <% if category.services.any? %>
                  <span class="ml-1 text-xs text-slate-400">(<%= category.services.pluck(:name).join(", ") %>)</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium space-x-2">
                <%= link_to t('common.actions.edit'),
                    edit_dashboard_branch_service_category_path(@branch, category),
                    class: "text-primary-600 hover:text-primary-900" %>
                <%= button_to t('common.actions.delete'),
                    dashboard_branch_service_category_path(@branch, category),
                    method: :delete,
                    data: { turbo_confirm: t('common.confirm_delete') },
                    class: "text-red-600 hover:text-red-900 cursor-pointer" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card p-6 text-center">
      <p class="text-slate-500 mb-4"><%= t('views.dashboard.service_categories.index.no_categories_message') %></p>
      <%= link_to t('views.dashboard.service_categories.index.add_category'),
          new_dashboard_branch_service_category_path(@branch),
          class: "btn-primary" %>
    </div>
  <% end %>
</div>
