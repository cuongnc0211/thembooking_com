<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-4">

  <%# Add new closure form %>
  <div class="dashboard-card p-6">
    <div class="mb-1">
      <h1 class="text-xl font-bold text-white"><%= t('views.dashboard.business_closures.index.title') %></h1>
      <%= link_to "← Back to Branch", dashboard_branch_path(@branch), class: "text-xs text-slate-500 hover:text-slate-300 transition-colors" %>
    </div>
    <p class="text-sm text-slate-400 mt-1 mb-5"><%= t('views.dashboard.business_closures.index.subtitle') %></p>

    <%= form_with model: @closure, url: dashboard_branch_business_closures_path(@branch) do |f| %>
      <% if @closure.errors.any? %>
        <div class="mb-4 rounded-xl bg-rose-900/30 border border-rose-500/30 p-4 text-sm text-rose-300">
          <%= @closure.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-3"><%= t('views.dashboard.business_closures.index.add_title') %></p>
      <div class="flex flex-col sm:flex-row gap-4 items-end">
        <div>
          <%= f.label :date, t('views.dashboard.business_closures.index.date_label'), class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.date_field :date, class: "block w-full rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:ring-1 focus:ring-indigo-500/50", style: "background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);", min: Date.current %>
        </div>
        <div class="flex-1">
          <%= f.label :reason, t('views.dashboard.business_closures.index.reason_label'), class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.text_field :reason, class: "block w-full rounded-lg px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/50", style: "background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);", placeholder: t('views.dashboard.business_closures.index.reason_placeholder') %>
        </div>
        <%= f.submit t('views.dashboard.business_closures.index.add_button'),
              class: "px-4 py-2 text-sm font-semibold text-white rounded-lg cursor-pointer whitespace-nowrap",
              style: "background: linear-gradient(135deg, #4f46e5, #6366f1);" %>
      </div>
    <% end %>
  </div>

  <%# Closures list %>
  <div class="dashboard-card overflow-hidden">
    <% if @closures.empty? %>
      <div class="p-8 text-center">
        <p class="text-slate-400"><%= t('views.dashboard.business_closures.index.no_closures') %></p>
      </div>
    <% else %>
      <table class="min-w-full">
        <thead>
          <tr class="border-b border-white/6">
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-slate-500"><%= t('views.dashboard.business_closures.index.col_date') %></th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-slate-500"><%= t('views.dashboard.business_closures.index.col_reason') %></th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-slate-500"><%= t('common.actions_title') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <% @closures.each do |closure| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">
                <%= closure.date.strftime("%d %b %Y") %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-400">
                <%= closure.reason.presence || "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <%= button_to t('common.actions.remove'),
                      dashboard_branch_business_closure_path(@branch, closure),
                      method: :delete,
                      data: { turbo_confirm: t('common.confirm_delete') },
                      class: "text-red-400 hover:text-red-300 cursor-pointer transition-colors" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
