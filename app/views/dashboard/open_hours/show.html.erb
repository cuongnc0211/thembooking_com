<div class="max-w-4xl mx-auto mt-8 px-4">
  <div class="mb-4">
    <%= link_to "← Back to Branch", dashboard_branch_path(@branch), class: "text-sm text-slate-500 hover:text-slate-700" %>
  </div>

  <% if @branch.inherit_from_main? %>
    <div class="dashboard-card p-4 mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <p class="text-sm text-slate-300">
        Operating hours are inherited from
        <%= link_to "Main Branch", dashboard_branch_open_hour_path(@branch.main_branch), class: "text-indigo-400 hover:text-indigo-300 underline" %>.
        Changes there apply here automatically.
      </p>
      <%= button_to "Enable Independent Hours", enable_independence_dashboard_branch_path(@branch),
            method: :post,
            class: "px-4 py-2 text-sm font-semibold text-white rounded-xl flex-shrink-0 cursor-pointer",
            style: "background: linear-gradient(135deg, #4f46e5, #6366f1);",
            data: { turbo_confirm: "After this, updates to Main Branch hours won't apply here. Current hours will be copied to this branch. Continue?" } %>
    </div>
  <% end %>

  <!-- Operating Hours -->
  <div class="mt-8 card p-6">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold"><%= t('views.dashboard.open_hours.show.operating_hours_title') %></h3>
      <%= link_to t('views.dashboard.open_hours.show.edit_hours'), edit_dashboard_branch_open_hour_path(@branch), class: "text-sm text-primary-600 hover:text-primary-700" %>
    </div>

    <div class="space-y-3">
      <% Branch::WEEKDAYS.each do |day| %>
        <% day_hours = @branch.hours_for(day) %>
        <% if day_hours %>
          <div class="flex items-start justify-between py-2 border-b border-slate-100 last:border-0">
            <div class="flex-1">
              <span class="font-medium text-slate-700 capitalize inline-block w-28"><%= t("time.day_names_short.#{day}") %></span>
              <% if day_hours["closed"] %>
                <span class="text-slate-400 italic"><%= t('views.dashboard.open_hours.show.closed') %></span>
              <% else %>
                <span class="text-slate-900">
                  <%= day_hours["open"] %> - <%= day_hours["close"] %>
                </span>

                <% breaks = day_hours["breaks"] || [] %>
                <% if breaks.any? %>
                  <div class="ml-28 mt-1">
                    <span class="text-xs text-slate-500 uppercase"><%= t('views.dashboard.open_hours.show.breaks_label') %></span>
                    <% breaks.each do |break_period| %>
                      <span class="text-sm text-slate-600 ml-2">
                        <%= break_period["start"] %> - <%= break_period["end"] %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
