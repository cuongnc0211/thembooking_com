<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-4">
  <% if @branch.inherit_from_main? %>
    <div class="dashboard-card p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <p class="text-sm text-slate-300">
        Operating hours are inherited from
        <%= link_to "Main Branch", dashboard_branch_open_hour_path(@branch.main_branch), class: "text-indigo-400 hover:text-indigo-300 underline" %>.
        Changes there apply here automatically.
      </p>
      <%= button_to "Enable Independent Hours", enable_independence_dashboard_branch_path(@branch),
            method: :post,
            class: "px-4 py-2 text-sm font-semibold text-white rounded-xl flex-shrink-0 cursor-pointer",
            style: "background: linear-gradient(135deg, #4f46e5, #6366f1);",
            data: { turbo_confirm: "After this, updates to Main Branch hours won't apply here. Current hours will be copied to this branch. Continue?" } %>
    </div>
  <% end %>

  <div class="dashboard-card p-6">
    <div class="flex items-center justify-between mb-1">
      <h3 class="text-xl font-bold text-white"><%= t('views.dashboard.open_hours.show.operating_hours_title') %></h3>
      <%= link_to t('views.dashboard.open_hours.show.edit_hours'), edit_dashboard_branch_open_hour_path(@branch), class: "px-3 py-1.5 text-xs font-medium rounded-lg text-slate-300 border border-slate-600/40 hover:border-slate-500 transition-colors" %>
    </div>
    <%= link_to "← Back to Branch", dashboard_branch_path(@branch), class: "text-xs text-slate-500 hover:text-slate-300 transition-colors block mb-4" %>

    <div class="border-t border-white/6 pt-4 space-y-1">
      <% Branch::WEEKDAYS.each do |day| %>
        <% day_hours = @branch.hours_for(day) %>
        <% if day_hours %>
          <div class="flex items-start py-2 border-b border-white/4 last:border-0">
            <span class="font-medium text-slate-300 capitalize w-28 flex-shrink-0"><%= t("time.day_names_short.#{day}") %></span>
            <% if day_hours["closed"] %>
              <span class="text-slate-500 italic text-sm"><%= t('views.dashboard.open_hours.show.closed') %></span>
            <% else %>
              <div>
                <span class="text-white text-sm"><%= day_hours["open"] %> – <%= day_hours["close"] %></span>
                <% breaks = day_hours["breaks"] || [] %>
                <% if breaks.any? %>
                  <div class="mt-1 flex flex-wrap gap-2 items-center">
                    <span class="text-xs text-slate-500 uppercase tracking-wider"><%= t('views.dashboard.open_hours.show.breaks_label') %></span>
                    <% breaks.each do |break_period| %>
                      <span class="text-xs text-slate-400 px-2 py-0.5 rounded-full" style="background: rgba(255,255,255,0.05);">
                        <%= break_period["start"] %> – <%= break_period["end"] %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
