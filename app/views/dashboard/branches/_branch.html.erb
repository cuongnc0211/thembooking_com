<div class="card p-6 hover:shadow-lg transition-shadow">
  <div class="flex justify-between items-start mb-4">
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-1">
        <h2 class="text-xl font-bold text-slate-900"><%= branch.name %></h2>
        <% if branch.active? %>
          <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-green-100 text-green-800">Active</span>
        <% else %>
          <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-slate-100 text-slate-500">Inactive</span>
        <% end %>
      </div>
      <p class="text-sm text-primary-600 font-mono"><%= branch.booking_url %></p>
    </div>
  </div>

  <dl class="space-y-2 mb-5 text-sm text-slate-600">
    <% if branch.address.present? %>
      <div class="flex gap-2">
        <dt class="font-medium text-slate-500 w-20 shrink-0">Address</dt>
        <dd><%= branch.address %></dd>
      </div>
    <% end %>
    <% if branch.phone.present? %>
      <div class="flex gap-2">
        <dt class="font-medium text-slate-500 w-20 shrink-0">Phone</dt>
        <dd><%= branch.phone %></dd>
      </div>
    <% end %>
    <div class="flex gap-2">
      <dt class="font-medium text-slate-500 w-20 shrink-0">Capacity</dt>
      <dd><%= branch.capacity %> <%= "person".pluralize(branch.capacity) %></dd>
    </div>
  </dl>

  <div class="flex items-center gap-3 pt-4 border-t border-slate-100">
    <%= link_to "Manage", dashboard_branch_path(branch), class: "btn-primary py-1.5 px-4 text-sm" %>
    <%= link_to "Edit", edit_dashboard_branch_path(branch), class: "btn-secondary py-1.5 px-4 text-sm" %>
    <%= button_to branch.active? ? "Deactivate" : "Activate",
          dashboard_branch_path(branch),
          method: :delete,
          data: { turbo_confirm: branch.active? ? "Deactivate this branch?" : "Activate this branch?" },
          class: "text-sm font-medium #{branch.active? ? 'text-red-600 hover:text-red-800' : 'text-emerald-600 hover:text-emerald-800'} cursor-pointer" %>
  </div>
</div>
