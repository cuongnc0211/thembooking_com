<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-4">

  <!-- Main card -->
  <div class="dashboard-card p-6">
    <!-- Branch header -->
    <div class="flex items-start justify-between mb-4">
      <div>
        <h1 class="text-xl font-bold text-white mb-0.5"><%= @branch.name %></h1>
        <p class="text-sm text-slate-400">
          <%= [I18n.l(Date.today, format: :long), @branch.address].compact.join(' · ') %>
        </p>
      </div>
      <div class="flex items-center gap-2">
        <% if @branch.active? %>
          <span class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/30">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
            Active
          </span>
        <% else %>
          <span class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full bg-slate-700/50 text-slate-400 border border-slate-600/30">
            <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
            Inactive
          </span>
        <% end %>
        <%= link_to edit_dashboard_branch_path(@branch), class: "px-3 py-1.5 text-xs font-medium rounded-lg text-slate-300 border border-slate-600/40 hover:border-slate-500 transition-colors" do %>
          Chỉnh sửa
        <% end %>
        <%= link_to dashboard_branches_path, class: "text-xs px-2 py-1.5 text-slate-500 hover:text-slate-300 transition-colors" do %>
          ← Tất cả branches
        <% end %>
      </div>
    </div>

    <div class="border-t border-white/6 mb-4"></div>

    <!-- Booking URL -->
    <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-2">Booking URL</p>
    <div class="flex items-center gap-3 mb-1">
      <code class="flex-1 px-3 py-2.5 rounded-xl text-sm font-mono truncate text-slate-400" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.06);">
        <%= @branch.booking_url %>
      </code>
      <button
        class="px-4 py-2.5 text-sm font-semibold text-white rounded-xl flex-shrink-0"
        style="background: linear-gradient(135deg, #4f46e5, #6366f1);"
        onclick="navigator.clipboard.writeText('<%= @branch.booking_url %>');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)">
        Copy
      </button>
    </div>
    <p class="text-xs text-slate-500 mb-5">Share this URL with customers to let them book online.</p>

    <div class="border-t border-white/6 mb-4"></div>

    <!-- Action rows -->
    <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-3">Quản lý chi nhánh</p>
    <div class="space-y-2">
      <%= link_to dashboard_branch_bookings_path(@branch), class: "flex items-center gap-4 px-4 py-3 rounded-xl transition-all group", style: "background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05);" do %>
        <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold text-indigo-300" style="background: rgba(99,102,241,0.25);">LH</div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-white">Lịch hẹn</p>
          <p class="text-xs text-slate-400">Xem và quản lý lịch đặt</p>
        </div>
        <svg class="w-4 h-4 flex-shrink-0 text-slate-500 group-hover:text-slate-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

      <%= link_to dashboard_branch_services_path(@branch), class: "flex items-center gap-4 px-4 py-3 rounded-xl transition-all group", style: "background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05);" do %>
        <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold text-purple-300" style="background: rgba(139,92,246,0.25);">DV</div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-white">Dịch vụ</p>
          <p class="text-xs text-slate-400">Cấu hình dịch vụ và giá</p>
        </div>
        <svg class="w-4 h-4 flex-shrink-0 text-slate-500 group-hover:text-slate-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

      <%= link_to edit_dashboard_branch_open_hour_path(@branch), class: "flex items-center gap-4 px-4 py-3 rounded-xl transition-all group", style: "background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05);" do %>
        <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold text-amber-300" style="background: rgba(245,158,11,0.25);">GH</div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-white">Giờ làm việc</p>
          <p class="text-xs text-slate-400">Thiết lập giờ mở cửa</p>
        </div>
        <svg class="w-4 h-4 flex-shrink-0 text-slate-500 group-hover:text-slate-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

      <%= link_to dashboard_branch_business_closures_path(@branch), class: "flex items-center gap-4 px-4 py-3 rounded-xl transition-all group", style: "background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05);" do %>
        <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold text-red-300" style="background: rgba(239,68,68,0.2);">ND</div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-white">Ngày đóng cửa</p>
          <p class="text-xs text-slate-400">Quản lý lịch nghỉ</p>
        </div>
        <svg class="w-4 h-4 flex-shrink-0 text-slate-500 group-hover:text-slate-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
  </div>

  <!-- Stat cards row -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="dashboard-card p-5">
      <p class="text-sm text-slate-400 mb-3">Chi tiết chi nhánh</p>
      <div class="space-y-2">
        <% if @branch.address.present? %>
          <div class="flex gap-3 text-sm">
            <span class="text-slate-500 min-w-20">Địa chỉ</span>
            <span class="text-white font-medium"><%= @branch.address %></span>
          </div>
        <% end %>
        <% if @branch.phone.present? %>
          <div class="flex gap-3 text-sm">
            <span class="text-slate-500 min-w-20">Điện thoại</span>
            <span class="text-white font-medium"><%= @branch.phone %></span>
          </div>
        <% end %>
        <div class="flex gap-3 text-sm">
          <span class="text-slate-500 min-w-20">Sức chứa</span>
          <span class="text-white font-medium"><%= @branch.capacity %> <%= "person".pluralize(@branch.capacity) %></span>
        </div>
      </div>
    </div>

    <div class="dashboard-card p-5">
      <p class="text-sm text-slate-400 mb-3">Vận hành hôm nay</p>
      <%= link_to dashboard_branch_operations_path(@branch), class: "flex items-center justify-between group" do %>
        <div>
          <p class="text-2xl font-bold text-white">Operations</p>
          <p class="text-xs mt-1 text-indigo-400">Xem lịch hẹn trực tiếp →</p>
        </div>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(99,102,241,0.2);">
          <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
      <% end %>
    </div>
  </div>

</div>
