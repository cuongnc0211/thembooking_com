<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

  <!-- Branch header -->
  <div class="flex items-start justify-between mb-6">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <h1 class="text-xl font-semibold text-white"><%= @branch.name %></h1>
        <% if @branch.active? %>
          <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/30">Active</span>
        <% else %>
          <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-slate-700/50 text-slate-400 border border-slate-600/30">Inactive</span>
        <% end %>
      </div>
      <p class="text-slate-500 text-sm">
        <%= [@branch.address, @branch.phone].compact.join(' · ') %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Edit Branch", edit_dashboard_branch_path(@branch),
            class: "px-4 py-2 text-sm text-slate-300 border border-slate-600/50 rounded-lg hover:border-slate-500 hover:text-slate-200 transition-colors" %>
      <%= link_to "← All Branches", dashboard_branches_path,
            class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-300 transition-colors flex items-center gap-1" %>
    </div>
  </div>

  <!-- Booking URL -->
  <div class="bg-slate-800/50 border border-slate-700/40 rounded-xl p-4 mb-4">
    <p class="text-xs text-slate-400 font-medium uppercase tracking-wide mb-2">Booking URL</p>
    <div class="flex items-center gap-3">
      <code class="flex-1 bg-[#0f172a]/80 border border-slate-700/40 rounded-lg px-3 py-2 text-sm font-mono text-slate-400 truncate">
        <%= @branch.booking_url %>
      </code>
      <button
        class="px-4 py-2 text-sm font-medium text-white rounded-lg flex-shrink-0"
        style="background: linear-gradient(135deg, #4f46e5, #6366f1);"
        onclick="navigator.clipboard.writeText('<%= @branch.booking_url %>');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)">
        Copy
      </button>
    </div>
    <p class="mt-2 text-xs text-slate-500">Share this URL with customers to let them book online.</p>
  </div>

  <!-- Quick action tiles -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
    <%= link_to dashboard_branch_bookings_path(@branch),
          class: "bg-slate-800/50 border border-slate-700/30 rounded-xl p-4 flex flex-col items-center gap-2.5 hover:bg-indigo-500/8 hover:border-indigo-500/30 transition-all group" do %>
      <div class="w-10 h-10 rounded-xl bg-indigo-500/15 flex items-center justify-center group-hover:bg-indigo-500/20 transition-colors">
        <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <span class="text-sm font-medium text-slate-300">Bookings</span>
    <% end %>

    <%= link_to dashboard_branch_services_path(@branch),
          class: "bg-slate-800/50 border border-slate-700/30 rounded-xl p-4 flex flex-col items-center gap-2.5 hover:bg-purple-500/8 hover:border-purple-500/30 transition-all group" do %>
      <div class="w-10 h-10 rounded-xl bg-purple-500/15 flex items-center justify-center group-hover:bg-purple-500/20 transition-colors">
        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
      </div>
      <span class="text-sm font-medium text-slate-300">Services</span>
    <% end %>

    <%= link_to edit_dashboard_branch_open_hour_path(@branch),
          class: "bg-slate-800/50 border border-slate-700/30 rounded-xl p-4 flex flex-col items-center gap-2.5 hover:bg-amber-500/8 hover:border-amber-500/30 transition-all group" do %>
      <div class="w-10 h-10 rounded-xl bg-amber-500/15 flex items-center justify-center group-hover:bg-amber-500/20 transition-colors">
        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <span class="text-sm font-medium text-slate-300">Operating Hours</span>
    <% end %>

    <%= link_to dashboard_branch_business_closures_path(@branch),
          class: "bg-slate-800/50 border border-slate-700/30 rounded-xl p-4 flex flex-col items-center gap-2.5 hover:bg-red-500/8 hover:border-red-500/30 transition-all group" do %>
      <div class="w-10 h-10 rounded-xl bg-red-500/15 flex items-center justify-center group-hover:bg-red-500/20 transition-colors">
        <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
        </svg>
      </div>
      <span class="text-sm font-medium text-slate-300">Closed Dates</span>
    <% end %>
  </div>

  <!-- Branch details -->
  <div class="bg-slate-800/50 border border-slate-700/40 rounded-xl p-4">
    <h3 class="text-sm font-medium text-slate-200 mb-3">Branch Details</h3>
    <dl class="space-y-0">
      <% if @branch.address.present? %>
        <div class="flex py-2.5 border-b border-slate-700/30">
          <dt class="text-slate-500 text-sm w-28 shrink-0">Address</dt>
          <dd class="text-slate-200 text-sm"><%= @branch.address %></dd>
        </div>
      <% end %>
      <% if @branch.phone.present? %>
        <div class="flex py-2.5 border-b border-slate-700/30">
          <dt class="text-slate-500 text-sm w-28 shrink-0">Phone</dt>
          <dd class="text-slate-200 text-sm"><%= @branch.phone %></dd>
        </div>
      <% end %>
      <div class="flex py-2.5">
        <dt class="text-slate-500 text-sm w-28 shrink-0">Capacity</dt>
        <dd class="text-slate-200 text-sm"><%= @branch.capacity %> <%= "person".pluralize(@branch.capacity) %></dd>
      </div>
    </dl>
  </div>

</div>
