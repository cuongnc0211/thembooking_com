<%= turbo_stream_from "branch_#{@branch.id}_bookings" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-4">
  <!-- Header -->
  <div class="dashboard-card p-6">
    <div class="flex items-center justify-between mb-1">
      <h1 class="text-xl font-bold text-white">Bookings</h1>
      <%= link_to "+ Walk-In", new_dashboard_branch_booking_path(@branch),
            class: "px-3 py-1.5 text-xs font-semibold text-white rounded-lg cursor-pointer",
            style: "background: linear-gradient(135deg, #4f46e5, #6366f1);" %>
    </div>
    <%= link_to "← Back to Branch", dashboard_branch_path(@branch), class: "text-xs text-slate-500 hover:text-slate-300 transition-colors" %>
  </div>

  <!-- Capacity Indicator -->
  <%= render "capacity_indicator", branch: @branch, current_capacity: @current_capacity, total_capacity: @total_capacity, capacity_percentage: @capacity_percentage %>

  <!-- Date Navigation -->
  <div class="dashboard-card p-4">
    <div class="flex items-center justify-between">
      <%= link_to "← Previous", dashboard_branch_bookings_path(@branch, date: (@date - 1.day).to_s, status: params[:status], service_id: params[:service_id], search: params[:search]),
            class: "text-sm text-slate-400 hover:text-slate-200 font-medium transition-colors" %>

      <div class="text-center">
        <div class="text-base font-semibold text-white">
          <%= @date == Date.current ? "Today" : @date.strftime("%B %d, %Y") %>
        </div>
        <div class="text-xs text-slate-400">
          <%= @date.strftime("%A") %>
        </div>
      </div>

      <%= link_to "Next →", dashboard_branch_bookings_path(@branch, date: (@date + 1.day).to_s, status: params[:status], service_id: params[:service_id], search: params[:search]),
            class: "text-sm text-slate-400 hover:text-slate-200 font-medium transition-colors" %>
    </div>
  </div>

  <!-- Filters -->
  <div class="dashboard-card p-4">
    <%= form_with url: dashboard_branch_bookings_path(@branch), method: :get, class: "flex gap-4 flex-wrap items-end" do %>
      <%= hidden_field_tag :date, @date.to_s %>

      <div class="flex-1 min-w-[150px]">
        <%= label_tag :status, "Status", class: "block text-xs font-medium text-slate-400 mb-1" %>
        <%= select_tag :status,
            options_for_select(
              [
                ["All Statuses", ""],
                ["Pending", "pending"],
                ["Confirmed", "confirmed"],
                ["In Progress", "in_progress"],
                ["Completed", "completed"],
                ["Cancelled", "cancelled"],
                ["No Show", "no_show"]
              ],
              params[:status]
            ),
            class: "w-full rounded-lg text-sm text-white focus:outline-none focus:ring-1 focus:ring-indigo-500/50 px-3 py-2",
            style: "background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);",
            onchange: "this.form.requestSubmit()"
        %>
      </div>

      <div class="flex-1 min-w-[150px]">
        <%= label_tag :service_id, "Service", class: "block text-xs font-medium text-slate-400 mb-1" %>
        <%= select_tag :service_id,
            options_for_select(
              [["All Services", ""]] + @services.map { |s| [s.name, s.id] },
              params[:service_id]
            ),
            class: "w-full rounded-lg text-sm text-white focus:outline-none focus:ring-1 focus:ring-indigo-500/50 px-3 py-2",
            style: "background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);",
            onchange: "this.form.requestSubmit()"
        %>
      </div>

      <div class="flex-1 min-w-[200px]">
        <%= label_tag :search, "Search", class: "block text-xs font-medium text-slate-400 mb-1" %>
        <%= text_field_tag :search, params[:search],
            placeholder: "Customer name or phone",
            class: "w-full rounded-lg text-sm text-white placeholder-slate-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/50 px-3 py-2",
            style: "background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);"
        %>
      </div>

      <div class="flex gap-2">
        <%= submit_tag "Filter", class: "px-3 py-2 text-sm font-semibold text-white rounded-lg cursor-pointer", style: "background: rgba(99,102,241,0.25); border: 1px solid rgba(99,102,241,0.3);" %>
        <% if params[:status].present? || params[:service_id].present? || params[:search].present? %>
          <%= link_to "Clear", dashboard_branch_bookings_path(@branch, date: @date.to_s), class: "px-3 py-2 text-sm text-slate-400 hover:text-slate-200 transition-colors" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Bookings List -->
  <% if @bookings.any? %>
    <div class="space-y-3">
      <% @bookings.each do |booking| %>
        <%= render "booking_card", booking: booking, branch: @branch %>
      <% end %>
    </div>
  <% else %>
    <div class="dashboard-card p-8 text-center">
      <p class="text-slate-400 text-base mb-4">No bookings found for this date</p>
      <% if @date == Date.current %>
        <%= link_to "+ Add Walk-In", new_dashboard_branch_booking_path(@branch),
              class: "px-4 py-2 text-sm font-semibold text-white rounded-lg",
              style: "background: linear-gradient(135deg, #4f46e5, #6366f1);" %>
      <% end %>
    </div>
  <% end %>
</div>
