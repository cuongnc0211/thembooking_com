<%= form_with model: business, url: dashboard_business_path, method: (business.persisted? ? :patch : :post), class: "space-y-6" do |form| %>
  <% if business.errors.any? %>
    <div class="bg-red-50 border border-red-100 text-red-700 px-4 py-3 rounded-xl">
      <ul class="list-disc list-inside">
        <% business.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Logo Upload -->
  <div>
    <%= form.label :logo, t('views.dashboard.businesses.form.logo_label'), class: "form-label" %>
    <div class="mt-2 p-4 border-2 border-dashed border-slate-200 rounded-xl hover:border-primary-400 transition-colors bg-slate-50/50">
      <% if business.logo.attached? %>
        <div class="flex items-center space-x-6">
          <%= image_tag business.logo.variant(resize_to_limit: [100, 100]), class: "h-20 w-20 rounded-lg object-cover shadow-sm" %>
          <div>
            <%= form.file_field :logo, class: "hidden", id: "logo-upload" %>
            <label for="logo-upload" class="btn-secondary py-2 px-4 text-sm cursor-pointer">
              <%= t('views.dashboard.businesses.form.logo_change') %>
            </label>
            <p class="mt-2 text-xs text-slate-500"><%= t('views.dashboard.businesses.form.logo_hint') %></p>
          </div>
        </div>
      <% else %>
        <div class="text-center">
          <svg class="mx-auto h-12 w-12 text-slate-300" stroke="currentColor" fill="none" viewBox="0 0 48 48">
            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <div class="mt-4 flex text-sm text-slate-600 justify-center">
            <label for="logo-upload" class="relative cursor-pointer rounded-md font-medium text-primary-600 hover:text-primary-500 focus-within:outline-none">
              <span><%= t('views.dashboard.businesses.form.logo_upload') %></span>
              <%= form.file_field :logo, class: "sr-only", id: "logo-upload" %>
            </label>
            <p class="pl-1"><%= t('views.dashboard.businesses.form.logo_drag') %></p>
          </div>
          <p class="text-xs text-slate-500"><%= t('views.dashboard.businesses.form.logo_types') %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Business Name -->
  <div>
    <%= form.label :name, t('views.dashboard.businesses.form.name_label'), class: "form-label" %>
    <%= form.text_field :name, class: "form-input", placeholder: t('views.dashboard.businesses.form.name_placeholder') %>
  </div>

  <!-- Business Type -->
  <div>
    <%= form.label :business_type, t('views.dashboard.businesses.form.type_label'), class: "form-label" %>
    <%= form.select :business_type, Business.business_types.keys.map { |t| [t.titleize, t] }, { prompt: t('views.dashboard.businesses.form.type_prompt') }, class: "form-input" %>
  </div>

  <!-- Description -->
  <div>
    <%= form.label :description, t('views.dashboard.businesses.form.description_label'), class: "form-label" %>
    <%= form.text_area :description, rows: 4, class: "form-input", placeholder: t('views.dashboard.businesses.form.description_placeholder') %>
  </div>

  <!-- Submit Button -->
  <div class="flex justify-end pt-4 border-slate-100">
    <%= form.submit business.persisted? ? t('views.dashboard.businesses.form.submit_update') : t('views.dashboard.businesses.form.submit_create'), class: "btn-primary cursor-pointer" %>
  </div>
<% end %>
