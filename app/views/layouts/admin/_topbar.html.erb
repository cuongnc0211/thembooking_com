<header class="fixed top-0 left-0 right-0 z-50 h-16 bg-gray-900 border-b border-gray-800 flex items-center px-4">
  <%# Mobile hamburger %>
  <button data-action="sidebar#toggle" class="md:hidden mr-3 text-gray-400 hover:text-white">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <%# Logo %>
  <%= link_to admin_root_path, class: "flex items-center" do %>
    <span class="text-lg font-bold text-white">ThemBooking</span>
    <span class="ml-2 text-xs font-medium bg-indigo-500/20 text-indigo-300 px-2 py-0.5 rounded-full">Admin</span>
  <% end %>

  <div class="flex-1"></div>

  <%# Staff info + sign out %>
  <div class="flex items-center gap-4">
    <div class="hidden sm:block text-right">
      <p class="text-sm font-medium text-white"><%= current_staff.name %></p>
      <p class="text-xs text-gray-400"><%= current_staff.role.humanize %></p>
    </div>
    <%= button_to admin_sign_out_path, method: :delete,
        class: "text-gray-400 hover:text-white transition-colors p-2 rounded-lg hover:bg-gray-800 cursor-pointer" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
    <% end %>
  </div>
</header>
