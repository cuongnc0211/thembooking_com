<aside data-sidebar-target="sidebar"
       class="fixed inset-y-0 left-0 z-40 w-60 bg-white border-r border-gray-200
              transform -translate-x-full md:translate-x-0 transition-transform duration-200
              md:top-16 md:bottom-0 pt-16 md:pt-0 overflow-y-auto">

  <%# Mobile close button %>
  <div class="md:hidden flex justify-end p-3">
    <button data-action="sidebar#close" class="text-gray-400 hover:text-gray-600 p-1">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <nav class="px-3 py-4 space-y-1">
    <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Main</p>

    <%= link_to admin_root_path,
        class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-colors
               #{request.path == admin_root_path ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
      <svg class="mr-3 h-5 w-5 flex-shrink-0 <%= request.path == admin_root_path ? 'text-indigo-600' : 'text-gray-400' %>"
           fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Dashboard
    <% end %>

    <%= link_to admin_users_path,
        class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-colors
               #{request.path.start_with?(admin_users_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
      <svg class="mr-3 h-5 w-5 flex-shrink-0 <%= request.path.start_with?(admin_users_path) ? 'text-indigo-600' : 'text-gray-400' %>"
           fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
      </svg>
      Users
    <% end %>

    <%= link_to admin_businesses_path,
        class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-colors
               #{request.path.start_with?(admin_businesses_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
      <svg class="mr-3 h-5 w-5 flex-shrink-0 <%= request.path.start_with?(admin_businesses_path) ? 'text-indigo-600' : 'text-gray-400' %>"
           fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
      Businesses
    <% end %>

    <% if current_staff&.super_admin? %>
      <%= link_to admin_promotion_codes_path,
          class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-colors
                 #{request.path.start_with?(admin_promotion_codes_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
        <svg class="mr-3 h-5 w-5 flex-shrink-0 <%= request.path.start_with?(admin_promotion_codes_path) ? 'text-indigo-600' : 'text-gray-400' %>"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
        </svg>
        Promotions
      <% end %>

      <%= link_to admin_staffs_path,
          class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-colors
                 #{request.path.start_with?(admin_staffs_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
        <svg class="mr-3 h-5 w-5 flex-shrink-0 <%= request.path.start_with?(admin_staffs_path) ? 'text-indigo-600' : 'text-gray-400' %>"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Staffs
      <% end %>
    <% end %>
  </nav>
</aside>
