<aside data-sidebar-target="sidebar" class="
    fixed inset-y-0 left-0 z-40 w-56
    bg-gradient-to-b from-[#0a0f1e]/98 to-[#080c1a]/99
    border-r border-indigo-900/20 backdrop-filter backdrop-blur-xl
    transform -translate-x-full transition-transform duration-300 ease-in-out
    md:translate-x-0 md:fixed md:top-0 md:bottom-0 md:h-screen
    md:block md:overflow-y-auto
  ">

  <div class="h-full flex flex-col">
    <!-- Logo -->
    <div class="px-5 py-5 border-b border-indigo-900/20 flex-shrink-0">
      <%= link_to root_path, class: "flex items-center" do %>
        <span class="text-xl font-display font-bold text-gradient">ThemBooking</span>
      <% end %>
    </div>

    <!-- Mobile Close Button -->
    <div class="md:hidden absolute top-4 right-4">
      <button data-action="sidebar#close" class="p-2 rounded-lg text-slate-500 hover:text-slate-300 hover:bg-slate-800/50 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <p class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2 mt-1">Menu</p>

      <!-- Branches -->
      <% branches_active = request.path.start_with?('/dashboard/branches') || request.path == dashboard_root_path %>
      <%= link_to dashboard_branches_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg transition-all duration-150 border-l-2 #{branches_active ? 'bg-indigo-500/10 border-indigo-500 text-indigo-300' : 'border-transparent text-slate-400 hover:bg-slate-800/30 hover:text-slate-200'}" do %>
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Branches
      <% end %>

      <!-- Analytics (soon) -->
      <span class="flex items-center gap-3 px-3 py-2.5 text-sm border-l-2 border-transparent text-slate-600 cursor-not-allowed select-none">
        <svg class="w-4 h-4 flex-shrink-0 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Analytics
        <span class="ml-auto text-[10px] font-bold bg-slate-800 text-slate-500 py-0.5 px-2 rounded-full"><%= I18n.locale == :en ? "SOON" : "SẮP CÓ" %></span>
      </span>

      <div class="mx-3 my-3 h-px bg-indigo-900/30"></div>
      <p class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Cài đặt</p>

      <!-- Business Profile -->
      <% business_active = request.path == dashboard_business_path %>
      <%= link_to dashboard_business_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg transition-all duration-150 border-l-2 #{business_active ? 'bg-indigo-500/10 border-indigo-500 text-indigo-300' : 'border-transparent text-slate-400 hover:bg-slate-800/30 hover:text-slate-200'}" do %>
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        <%= t('navigation.business_profile') %>
      <% end %>

      <!-- Account Settings -->
      <% profile_active = request.path == edit_dashboard_profile_path %>
      <%= link_to edit_dashboard_profile_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg transition-all duration-150 border-l-2 #{profile_active ? 'bg-indigo-500/10 border-indigo-500 text-indigo-300' : 'border-transparent text-slate-400 hover:bg-slate-800/30 hover:text-slate-200'}" do %>
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <%= t('navigation.account_settings') %>
      <% end %>
    </nav>

    <!-- Footer: Language + Logout -->
    <div class="px-3 py-4 border-t border-indigo-900/20 flex-shrink-0 space-y-0.5">
      <!-- Mobile Language Switcher -->
      <div data-controller="dropdown" class="relative md:hidden">
        <button data-action="click->dropdown#toggle" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg border-l-2 border-transparent text-slate-400 hover:bg-slate-800/30 hover:text-slate-200 transition-all w-full text-left">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
          <%= t('navigation.language') %>
        </button>
        <div data-dropdown-target="menu" class="hidden mt-1 ml-4 space-y-1">
          <%= button_to locale_path, method: :patch, params: { locale: "en" }, class: "flex items-center w-full px-3 py-2 text-sm text-slate-400 hover:text-slate-200 rounded-lg" do %>
            <span class="mr-2">🇬🇧</span> English
          <% end %>
          <%= button_to locale_path, method: :patch, params: { locale: "vi" }, class: "flex items-center w-full px-3 py-2 text-sm text-slate-400 hover:text-slate-200 rounded-lg" do %>
            <span class="mr-2">🇻🇳</span> Tiếng Việt
          <% end %>
        </div>
      </div>

      <%= button_to session_path, method: :delete, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg border-l-2 border-transparent text-slate-500 hover:bg-red-900/20 hover:text-red-400 hover:border-red-500/50 transition-all w-full text-left cursor-pointer" do %>
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        <%= t('navigation.sign_out') %>
      <% end %>
    </div>
  </div>
</aside>
