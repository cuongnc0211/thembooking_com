          <blockquote class="text-slate-300 leading-relaxed text-sm flex-1 mb-6">
            "<%= t("views.home.index.testimonial_#{i}_quote") %>"
          </blockquote>
          <div class="flex items-center gap-4 pt-5 border-t border-white/10 mt-auto">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500/30 to-primary-600/20 border border-primary-500/20 flex items-center justify-center flex-shrink-0">
              <span class="text-primary-300 font-bold text-xs"><%= t("views.home.index.testimonial_#{i}_initials") %></span>
            </div>
            <div>
              <p class="font-semibold text-white text-sm"><%= t("views.home.index.testimonial_#{i}_name") %></p>
              <p class="text-slate-500 text-xs"><%= t("views.home.index.testimonial_#{i}_business") %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== CTA SECTION ===== %>
<section class="py-28 relative overflow-hidden">
  <div class="absolute inset-0 aurora-bg z-0"></div>
  <div class="absolute inset-0 z-0 opacity-20" style="background-image: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative z-10 max-w-4xl mx-auto text-center px-4 sm:px-6">
    <h2 class="text-4xl sm:text-5xl font-display font-bold text-white mb-6 leading-tight">
      <%= t('views.home.index.cta_title') %>
    </h2>
    <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto">
      <%= t('views.home.index.cta_subtitle') %>
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
      <% unless authenticated? %>
        <%= link_to t('views.home.index.get_started'), new_registration_path,
            class: "btn-primary text-base px-10 py-4 shadow-xl shadow-primary-500/30 hover:shadow-primary-500/50 cursor-pointer" %>
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-slate-500">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <%= t('views.home.index.trust_indicator_1') %>
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <%= t('views.home.index.trust_indicator_2') %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</section>
