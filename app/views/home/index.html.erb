<% content_for :body_class, "bg-[#0A0A0A] text-slate-100" %>
<% content_for :nav_class, "bg-white/5 backdrop-blur-md" %>

<% content_for :footer_override do %>
<footer class="bg-[#0A0A0A] border-t border-white/10 mt-auto">
  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <span class="text-xl font-display font-bold text-white"><%= t('navigation.brand') %></span>
        <p class="mt-4 text-sm text-slate-500 max-w-xs"><%= t('footer.tagline') %></p>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-slate-400 tracking-wider uppercase mb-4"><%= t('footer.product') %></h3>
        <ul class="space-y-3">
          <li><a href="#features" class="text-sm text-slate-500 hover:text-primary-400 transition-colors cursor-pointer"><%= t('footer.features') %></a></li>
          <li><a href="#pricing" class="text-sm text-slate-500 hover:text-primary-400 transition-colors cursor-pointer"><%= t('footer.pricing') %></a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-slate-400 tracking-wider uppercase mb-4"><%= t('footer.company') %></h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-sm text-slate-500 hover:text-primary-400 transition-colors cursor-pointer"><%= t('footer.about') %></a></li>
          <li><a href="#" class="text-sm text-slate-500 hover:text-primary-400 transition-colors cursor-pointer"><%= t('footer.contact') %></a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-slate-600">&copy; <%= Time.current.year %> <%= t('navigation.brand') %>. <%= t('footer.rights_reserved') %></p>
      <div class="flex space-x-6">
        <a href="#" class="text-slate-600 hover:text-slate-400 transition-colors cursor-pointer">
          <span class="sr-only">Twitter</span>
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/></svg>
        </a>
        <a href="#" class="text-slate-600 hover:text-slate-400 transition-colors cursor-pointer">
          <span class="sr-only">GitHub</span>
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
<% end %>

<%# ===== HERO SECTION ===== %>
<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <%# Aurora background %>
  <div class="absolute inset-0 aurora-bg z-0"></div>
  <%# Subtle dot grid overlay %>
  <div class="absolute inset-0 z-0 opacity-20" style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <%# Left: Copy %>
      <div class="animate-fade-in-up">
        <%# Badge %>
        <div class="badge-pill bg-primary-500/15 border-primary-500/30 text-primary-300 mb-8 w-fit">
          <span class="flex h-2 w-2 rounded-full bg-primary-400"></span>
          <%= t('views.home.index.badge_text') %>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold leading-tight mb-6 text-white">
          <%= t('views.home.index.hero_title_dark').html_safe %>
        </h1>

        <p class="text-lg sm:text-xl text-slate-400 mb-10 max-w-lg leading-relaxed">
          <%= t('views.home.index.hero_subtitle') %>
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <% if authenticated? %>
            <%= link_to t('views.home.index.dashboard_button'), dashboard_root_path,
                class: "btn-primary text-base px-8 py-4 shadow-xl shadow-primary-500/30 hover:shadow-primary-500/50 cursor-pointer" %>
          <% else %>
            <%= link_to t('views.home.index.get_started'), new_registration_path,
                class: "btn-primary text-base px-8 py-4 shadow-xl shadow-primary-500/30 hover:shadow-primary-500/50 cursor-pointer" %>
            <%= link_to t('views.home.index.learn_more'), "#features",
                class: "inline-flex items-center justify-center px-8 py-4 rounded-xl border border-white/20 text-slate-300 hover:bg-white/5 hover:border-white/40 transition-all duration-300 font-medium cursor-pointer" %>
          <% end %>
        </div>

        <%# Stats row %>
        <div class="flex flex-wrap gap-8">
          <div>
            <p class="text-3xl font-display font-bold text-white"><%= t('views.home.index.stat_1_number') %></p>
            <p class="text-sm text-slate-500"><%= t('views.home.index.stat_1_label') %></p>
          </div>
          <div class="w-px bg-white/10 hidden sm:block"></div>
          <div>
            <p class="text-3xl font-display font-bold text-white"><%= t('views.home.index.stat_2_number') %></p>
            <p class="text-sm text-slate-500"><%= t('views.home.index.stat_2_label') %></p>
          </div>
          <div class="w-px bg-white/10 hidden sm:block"></div>
          <div>
            <p class="text-3xl font-display font-bold text-white"><%= t('views.home.index.stat_3_number') %></p>
            <p class="text-sm text-slate-500"><%= t('views.home.index.stat_3_label') %></p>
          </div>
        </div>
      </div>

      <%# Right: UI Mockup %>
      <div class="relative hidden lg:block animate-fade-in-up" style="animation-delay: 0.2s;">
        <%# Main dashboard card %>
        <div class="dark-glass-card p-5 shadow-2xl">
          <%# Dashboard header %>
          <div class="flex items-center justify-between mb-5 pb-4 border-b border-white/10">
            <div>
              <p class="text-white font-semibold font-display"><%= t('views.home.index.mockup_shop_name') %></p>
              <p class="text-slate-500 text-xs mt-0.5"><%= t('views.home.index.mockup_date') %></p>
            </div>
            <div class="flex items-center gap-2 px-3 py-1.5 bg-green-500/15 rounded-full border border-green-500/20">
              <div class="w-1.5 h-1.5 rounded-full bg-green-400"></div>
              <span class="text-green-400 text-xs font-medium"><%= t('views.home.index.mockup_open') %></span>
            </div>
          </div>

          <%# Appointments list %>
          <p class="text-slate-500 text-xs font-medium uppercase tracking-wider mb-3"><%= t('views.home.index.mockup_today') %></p>
          <div class="space-y-2">
            <div class="flex items-center gap-3 p-3 bg-white/5 rounded-xl">
              <div class="w-9 h-9 rounded-full bg-blue-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-blue-400 text-xs font-bold">MN</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-white text-sm font-medium truncate"><%= t('views.home.index.mockup_customer_1') %></p>
                <p class="text-slate-500 text-xs"><%= t('views.home.index.mockup_service_1') %></p>
              </div>
              <span class="px-2 py-0.5 bg-green-500/15 text-green-400 text-xs rounded-full flex-shrink-0 border border-green-500/20"><%= t('views.home.index.mockup_status_confirmed') %></span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-white/5 rounded-xl">
              <div class="w-9 h-9 rounded-full bg-purple-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-purple-400 text-xs font-bold">TA</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-white text-sm font-medium truncate"><%= t('views.home.index.mockup_customer_2') %></p>
                <p class="text-slate-500 text-xs"><%= t('views.home.index.mockup_service_2') %></p>
              </div>
              <span class="px-2 py-0.5 bg-blue-500/15 text-blue-400 text-xs rounded-full flex-shrink-0 border border-blue-500/20"><%= t('views.home.index.mockup_status_in_service') %></span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-white/5 rounded-xl">
              <div class="w-9 h-9 rounded-full bg-orange-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-orange-400 text-xs font-bold">HL</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-white text-sm font-medium truncate"><%= t('views.home.index.mockup_customer_3') %></p>
                <p class="text-slate-500 text-xs"><%= t('views.home.index.mockup_service_3') %></p>
              </div>
              <span class="px-2 py-0.5 bg-amber-500/15 text-amber-400 text-xs rounded-full flex-shrink-0 border border-amber-500/20"><%= t('views.home.index.mockup_status_waiting') %></span>
            </div>
          </div>

          <%# Queue bar %>
          <div class="mt-4 p-3 bg-primary-500/10 rounded-xl border border-primary-500/20">
            <div class="flex items-center justify-between mb-2">
              <span class="text-slate-400 text-sm"><%= t('views.home.index.mockup_queue') %></span>
              <span class="text-primary-400 font-bold text-sm"><%= t('views.home.index.mockup_queue_count') %></span>
            </div>
            <div class="flex gap-1.5">
              <% 3.times do |i| %>
                <div class="h-2 flex-1 rounded-full bg-primary-500/40 <%= i == 0 ? 'bg-primary-500' : '' %>"></div>
              <% end %>
              <% 2.times do %>
                <div class="h-2 flex-1 rounded-full bg-white/10"></div>
              <% end %>
            </div>
          </div>
        </div>

        <%# Floating metric: total bookings %>
        <div class="absolute -top-5 -right-5 dark-glass-card p-4 shadow-xl">
          <p class="text-slate-400 text-xs mb-1"><%= t('views.home.index.mockup_metric_bookings_label') %></p>
          <p class="text-white font-display font-bold text-2xl"><%= t('views.home.index.mockup_metric_bookings') %></p>
          <p class="text-green-400 text-xs mt-0.5"><%= t('views.home.index.mockup_metric_bookings_trend') %></p>
        </div>

        <%# Floating metric: no-show reduced %>
        <div class="absolute -bottom-5 -left-5 dark-glass-card p-4 shadow-xl">
          <p class="text-slate-400 text-xs mb-1"><%= t('views.home.index.mockup_metric_noshow_label') %></p>
          <p class="text-white font-display font-bold text-2xl"><%= t('views.home.index.mockup_metric_noshow') %></p>
          <p class="text-primary-400 text-xs mt-0.5"><%= t('views.home.index.mockup_metric_noshow_sub') %></p>
        </div>

        <%# Decorative glow behind card %>
        <div class="absolute inset-0 bg-primary-500/5 rounded-3xl blur-3xl -z-10 scale-110"></div>
      </div>
    </div>
  </div>
</section>

<%# ===== SERVICE TYPES SECTION ===== %>
<section class="py-24 bg-white/3" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="badge-pill bg-primary-500/15 border-primary-500/30 text-primary-300 mb-6 mx-auto w-fit">
        <%= t('views.home.index.service_types_badge') %>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-5">
        <%= t('views.home.index.service_types_title') %>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        <%= t('views.home.index.service_types_subtitle') %>
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <% (1..3).each do |i| %>
        <div class="block-card-dark overflow-hidden group cursor-default">
          <%# Gradient image placeholder %>
          <div class="h-52 relative overflow-hidden">
            <div class="absolute inset-0 <%= ["bg-gradient-to-br from-blue-900/80 to-primary-800/60", "bg-gradient-to-br from-purple-900/80 to-pink-800/60", "bg-gradient-to-br from-teal-900/80 to-cyan-800/60"][i-1] %>"></div>
            <%# Pattern overlay %>
            <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, white 0, white 1px, transparent 0, transparent 50%); background-size: 20px 20px;"></div>
            <%# Service icon %>
            <div class="absolute inset-0 flex items-center justify-center">
              <% icons = [
                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>',
                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>',
                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>'
              ] %>
              <svg class="w-16 h-16 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <%= icons[i-1].html_safe %>
              </svg>
            </div>
            <%# Hover overlay %>
            <div class="absolute inset-0 bg-primary-500/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-lg font-display font-bold text-white"><%= t("views.home.index.service_type_#{i}_name") %></h3>
              <span class="px-2 py-0.5 bg-primary-500/15 text-primary-300 text-xs rounded-full border border-primary-500/20 flex-shrink-0 ml-3"><%= t("views.home.index.service_type_#{i}_tag") %></span>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed"><%= t("views.home.index.service_type_#{i}_description") %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== FEATURES / AMENITIES SECTION ===== %>
<section class="py-24" id="features">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="badge-pill bg-orange-500/15 border-orange-500/30 text-orange-300 mb-6 mx-auto w-fit">
        <%= t('views.home.index.features_badge') %>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-5">
        <%= t('views.home.index.solution_title') %>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        <%= t('views.home.index.solution_subtitle') %>
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-5">
      <%# Feature 1: Queue %>
      <div class="block-card-dark p-6 text-center group cursor-default">
        <div class="w-14 h-14 rounded-2xl bg-primary-500/15 border border-primary-500/20 flex items-center justify-center mx-auto mb-5 group-hover:bg-primary-500/25 transition-colors duration-300">
          <svg class="w-7 h-7 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <h3 class="font-display font-semibold text-white mb-2 text-sm leading-snug"><%= t('views.home.index.feature_queue_title') %></h3>
        <p class="text-slate-500 text-xs leading-relaxed"><%= t('views.home.index.feature_queue_description') %></p>
      </div>

      <%# Feature 2: Booking %>
      <div class="block-card-dark p-6 text-center group cursor-default">
        <div class="w-14 h-14 rounded-2xl bg-purple-500/15 border border-purple-500/20 flex items-center justify-center mx-auto mb-5 group-hover:bg-purple-500/25 transition-colors duration-300">
          <svg class="w-7 h-7 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="font-display font-semibold text-white mb-2 text-sm leading-snug"><%= t('views.home.index.feature_booking_title') %></h3>
        <p class="text-slate-500 text-xs leading-relaxed"><%= t('views.home.index.feature_booking_description') %></p>
      </div>

      <%# Feature 3: Walk-in %>
      <div class="block-card-dark p-6 text-center group cursor-default">
        <div class="w-14 h-14 rounded-2xl bg-teal-500/15 border border-teal-500/20 flex items-center justify-center mx-auto mb-5 group-hover:bg-teal-500/25 transition-colors duration-300">
          <svg class="w-7 h-7 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        </div>
        <h3 class="font-display font-semibold text-white mb-2 text-sm leading-snug"><%= t('views.home.index.feature_walkin_title') %></h3>
        <p class="text-slate-500 text-xs leading-relaxed"><%= t('views.home.index.feature_walkin_description') %></p>
      </div>

      <%# Feature 4: Capacity %>
      <div class="block-card-dark p-6 text-center group cursor-default">
        <div class="w-14 h-14 rounded-2xl bg-orange-500/15 border border-orange-500/20 flex items-center justify-center mx-auto mb-5 group-hover:bg-orange-500/25 transition-colors duration-300">
          <svg class="w-7 h-7 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <h3 class="font-display font-semibold text-white mb-2 text-sm leading-snug"><%= t('views.home.index.feature_capacity_title') %></h3>
        <p class="text-slate-500 text-xs leading-relaxed"><%= t('views.home.index.feature_capacity_description') %></p>
      </div>

      <%# Feature 5: Free Shop Landing Page %>
      <div class="block-card-dark p-6 text-center group cursor-default">
        <div class="w-14 h-14 rounded-2xl bg-emerald-500/15 border border-emerald-500/20 flex items-center justify-center mx-auto mb-5 group-hover:bg-emerald-500/25 transition-colors duration-300">
          <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="font-display font-semibold text-white mb-2 text-sm leading-snug"><%= t('views.home.index.feature_landing_title') %></h3>
        <p class="text-slate-500 text-xs leading-relaxed"><%= t('views.home.index.feature_landing_description') %></p>
      </div>

      <%# Feature 6: Business Insights Dashboard %>
      <div class="block-card-dark p-6 text-center group cursor-default">
        <div class="w-14 h-14 rounded-2xl bg-violet-500/15 border border-violet-500/20 flex items-center justify-center mx-auto mb-5 group-hover:bg-violet-500/25 transition-colors duration-300">
          <svg class="w-7 h-7 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="font-display font-semibold text-white mb-2 text-sm leading-snug"><%= t('views.home.index.feature_insights_title') %></h3>
        <p class="text-slate-500 text-xs leading-relaxed"><%= t('views.home.index.feature_insights_description') %></p>
      </div>
    </div>

    <%# Mid-section CTA glass card %>
    <div class="mt-12 dark-glass-card p-8 sm:p-10 text-center">
      <h3 class="text-2xl font-display font-bold text-white mb-3"><%= t('views.home.index.features_mid_cta_title') %></h3>
      <p class="text-slate-400 mb-6 max-w-xl mx-auto"><%= t('views.home.index.features_mid_cta_subtitle') %></p>
      <% unless authenticated? %>
        <%= link_to t('views.home.index.get_started'), new_registration_path,
            class: "btn-primary px-8 py-3 cursor-pointer inline-flex items-center gap-2" %>
      <% end %>
    </div>
  </div>
</section>

<%# ===== HOW IT WORKS SECTION ===== %>
<section class="py-24 relative overflow-hidden" style="background: linear-gradient(to bottom, #0A0A0A, #0f1a3a, #0A0A0A);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <div class="badge-pill bg-primary-500/15 border-primary-500/30 text-primary-300 mb-6 mx-auto w-fit">
        <%= t('views.home.index.how_it_works_badge') %>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-5">
        <%= t('views.home.index.how_it_works_title') %>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        <%= t('views.home.index.how_it_works_subtitle') %>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
      <%# Connecting line desktop %>
      <div class="hidden md:block absolute top-10 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-primary-500/40 to-transparent"></div>

      <% (1..4).each do |i| %>
        <div class="text-center relative group">
          <div class="relative mx-auto w-20 h-20 mb-6">
            <div class="absolute inset-0 rounded-full bg-primary-500/20 animate-ping opacity-0 group-hover:opacity-30 transition-opacity duration-300"></div>
            <div class="relative w-20 h-20 rounded-full border-2 border-primary-500/40 bg-primary-500/10 flex items-center justify-center text-primary-400 text-2xl font-display font-bold group-hover:border-primary-400 group-hover:bg-primary-500/20 transition-all duration-300">
              <%= i %>
            </div>
          </div>
          <h3 class="text-base font-display font-bold text-white mb-3"><%= t("views.home.index.step_#{i}_title") %></h3>
          <p class="text-slate-400 text-sm leading-relaxed"><%= t("views.home.index.step_#{i}_description") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== PRICING SECTION ===== %>
<section class="py-24 bg-white/3" id="pricing">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="badge-pill bg-primary-500/15 border-primary-500/30 text-primary-300 mb-6 mx-auto w-fit">
        <%= t('views.home.index.pricing_badge') %>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-5">
        <%= t('views.home.index.pricing_title') %>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        <%= t('views.home.index.pricing_subtitle') %>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto items-center">
      <%# Free Plan %>
      <div class="block-card-dark p-7">
        <h3 class="text-xl font-display font-bold text-white mb-2"><%= t('views.home.index.plan_free_name') %></h3>
        <div class="mb-7">
          <span class="text-4xl font-display font-bold text-white"><%= t('views.home.index.plan_free_price') %></span>
        </div>
        <ul class="space-y-3 mb-7">
          <% (1..4).each do |i| %>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-primary-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-slate-400 text-sm"><%= t("views.home.index.plan_free_feature_#{i}") %></span>
            </li>
          <% end %>
        </ul>
        <% unless authenticated? %>
          <%= link_to t('views.home.index.get_started'), new_registration_path,
              class: "w-full text-center inline-block px-6 py-3 rounded-xl border border-white/20 text-slate-300 hover:bg-white/5 transition-all duration-300 font-medium cursor-pointer text-sm" %>
        <% end %>
      </div>

      <%# Pro Plan (Popular) — elevated %>
      <div class="relative rounded-2xl p-px bg-gradient-to-b from-primary-500/60 to-primary-500/10 md:-translate-y-4">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
          <span class="px-5 py-1.5 bg-gradient-to-r from-primary-500 to-primary-600 text-white text-xs font-bold rounded-full shadow-lg shadow-primary-500/30"><%= t('views.home.index.popular_badge') %></span>
        </div>
        <div class="bg-[#0f172a] rounded-2xl p-7 h-full">
          <h3 class="text-xl font-display font-bold text-white mb-2"><%= t('views.home.index.plan_pro_name') %></h3>
          <div class="mb-7">
            <span class="text-4xl font-display font-bold text-white"><%= t('views.home.index.plan_pro_price') %></span>
            <span class="text-slate-500 text-sm">/<%= t('views.home.index.per_month') %></span>
          </div>
          <ul class="space-y-3 mb-7">
            <% (1..6).each do |i| %>
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-primary-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-slate-300 text-sm"><%= t("views.home.index.plan_pro_feature_#{i}") %></span>
              </li>
            <% end %>
          </ul>
          <% unless authenticated? %>
            <%= link_to t('views.home.index.get_started'), new_registration_path,
                class: "btn-primary w-full justify-center py-3 cursor-pointer text-sm" %>
          <% end %>
        </div>
      </div>

      <%# Business Plan %>
      <div class="block-card-dark p-7">
        <h3 class="text-xl font-display font-bold text-white mb-2"><%= t('views.home.index.plan_business_name') %></h3>
        <div class="mb-7">
          <span class="text-4xl font-display font-bold text-white"><%= t('views.home.index.plan_business_price') %></span>
          <span class="text-slate-500 text-sm">/<%= t('views.home.index.per_month') %></span>
        </div>
        <ul class="space-y-3 mb-7">
          <% (1..7).each do |i| %>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-primary-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-slate-400 text-sm"><%= t("views.home.index.plan_business_feature_#{i}") %></span>
            </li>
          <% end %>
        </ul>
        <% unless authenticated? %>
          <%= link_to t('views.home.index.get_started'), new_registration_path,
              class: "w-full text-center inline-block px-6 py-3 rounded-xl border border-white/20 text-slate-300 hover:bg-white/5 transition-all duration-300 font-medium cursor-pointer text-sm" %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ===== TESTIMONIALS SECTION ===== %>
<section class="py-24" id="testimonials">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="badge-pill bg-orange-500/15 border-orange-500/30 text-orange-300 mb-6 mx-auto w-fit">
        <%= t('views.home.index.testimonials_badge') %>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-5">
        <%= t('views.home.index.testimonials_title') %>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        <%= t('views.home.index.testimonials_subtitle') %>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% (1..3).each do |i| %>
        <div class="block-card-dark p-7 flex flex-col cursor-default">
          <div class="flex gap-1 mb-5">
            <% 5.times do %>
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
