<% content_for :body_class, "bg-[#0A0A0A] text-slate-100" %>
<% content_for :nav_class, "bg-white/5 backdrop-blur-md" %>
<% content_for :footer_override do %><% end %>

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Aurora background -->
  <div class="absolute inset-0 aurora-bg pointer-events-none"></div>
  <!-- Dot grid overlay -->
  <div class="absolute inset-0 pointer-events-none opacity-10" style="background-image: radial-gradient(circle, rgba(255,255,255,0.2) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative z-10 w-full max-w-md animate-fade-in-up">
    <!-- Brand -->
    <div class="text-center mb-8">
      <%= link_to root_path do %>
        <span class="text-2xl font-display font-bold gradient-text-hero">ThemBooking</span>
      <% end %>
    </div>

    <!-- Card -->
    <div class="dark-glass-card p-8 space-y-6">
      <!-- Header -->
      <div class="text-center">
        <h1 class="text-2xl font-display font-bold text-white mb-1"><%= t('views.registrations.new.title') %></h1>
        <p class="text-slate-400 text-sm"><%= t('views.registrations.new.subtitle') %></p>
      </div>

      <!-- Form -->
      <%= form_with model: @user, url: registration_path, data: { controller: "timezone" }, class: "space-y-5" do |form| %>
        <% if @user.errors.any? %>
          <div class="bg-red-500/10 border border-red-500/20 p-4 rounded-xl">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-300"><%= t('views.registrations.new.errors_title') %></h3>
                <ul class="mt-2 text-sm text-red-400 list-disc list-inside space-y-1">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        <% end %>

        <%= hidden_field_tag :detected_timezone, '', id: 'detected_timezone' %>

        <!-- Email Field -->
        <div>
          <%= form.label :email_address, t('activerecord.attributes.user.email_address'), class: "form-label-dark" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/>
              </svg>
            </div>
            <%= form.email_field :email_address,
                autofocus: true,
                autocomplete: "email",
                placeholder: t('views.registrations.new.email_placeholder'),
                class: "form-input-dark pl-10" %>
          </div>
        </div>

        <!-- Password Field -->
        <div>
          <%= form.label :password, t('activerecord.attributes.user.password'), class: "form-label-dark" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <%= form.password_field :password,
                autocomplete: "new-password",
                placeholder: t('views.registrations.new.password_placeholder'),
                class: "form-input-dark pl-10" %>
          </div>
          <p class="mt-2 text-xs text-slate-500 flex items-center gap-1">
            <svg class="h-4 w-4 text-slate-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= t('views.registrations.new.password_hint') %>
          </p>
        </div>

        <!-- Confirm Password Field -->
        <div>
          <%= form.label :password_confirmation, t('activerecord.attributes.user.password_confirmation'), class: "form-label-dark" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <%= form.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: t('views.registrations.new.password_confirmation_placeholder'),
                class: "form-input-dark pl-10" %>
          </div>
        </div>

        <!-- Submit Button -->
        <%= form.submit t('views.registrations.new.submit'), class: "btn-primary w-full cursor-pointer mt-2" %>
      <% end %>

      <!-- Divider -->
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-white/10"></div>
        </div>
        <div class="relative flex justify-center text-xs">
          <span class="px-4 bg-transparent text-slate-500"><%= t('views.registrations.new.have_account') %></span>
        </div>
      </div>

      <!-- Sign In Link -->
      <%= link_to t('views.registrations.new.sign_in_link'), new_session_path,
          class: "flex items-center justify-center w-full px-6 py-3 rounded-xl font-medium border border-white/15 text-slate-300 hover:bg-white/5 hover:border-white/25 transition-all duration-200" %>
    </div>

    <!-- Terms Notice -->
    <p class="mt-6 text-center text-xs text-slate-600">
      <%= t('views.registrations.new.terms_text') %>
      <a href="#" class="text-slate-400 hover:text-slate-300 font-medium transition-colors"><%= t('views.registrations.new.terms_of_service') %></a>
      <%= t('views.registrations.new.terms_and') %>
      <a href="#" class="text-slate-400 hover:text-slate-300 font-medium transition-colors"><%= t('views.registrations.new.privacy_policy') %></a>
    </p>
  </div>
</div>
